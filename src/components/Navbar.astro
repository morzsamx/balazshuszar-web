---
const links = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/work", label: "Work" },
  { href: "/contact", label: "Contact" },
];
---

<nav class="flex flex-row flex-grow gap-4 justify-end items-center">
  <ul class="flex flex-row">
    {links.map((link) => (
      <li class="mx-2 last:mr-0">
        <a href={link.href}>{link.label}</a>
      </li>
    ))}
  </ul>
</nav>